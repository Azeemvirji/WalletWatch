@{
    ViewData["isDashboard"] = true;
    var Date = ViewData["Date"];
}

<div class="row mb-4">
    <div class="col-md-6 d-flex align-items-center">
        <h3 class="fw-bold me-3">Dashboard</h3>
        <ejs-datepicker id="dashboardDate" 
                        placeholder="Select Month" 
                        value="@Date" 
                        format="MMMM yyyy" 
                        start="Year" 
                        depth="Year" 
                        change="onDateChange"
                        width="250px">
        </ejs-datepicker>
    </div>
</div>

@*Summary Widgets*@
<div class="row mb-4">

    <div class="col-md-4">
        <div class="d-flex flex-row widget summary income">
            <div class="d-flex flex-column justify-content-center p-5">
                <i class="fa-solid fa-dollar-sign fa-2xl"></i>
            </div>
            <div class="d-flex flex-column m-auto py-3">
                <span class="lead">Total Income</span>
                <h1 class="display-6 fw-bold">@ViewBag.TotalIncome</h1>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="d-flex flex-row widget summary expense">
            <div class="d-flex flex-column justify-content-center p-5">
                <i class="fa-solid fa-dollar-sign fa-2xl"></i>
            </div>
            <div class="d-flex flex-column m-auto py-3">
                <span class="lead">Total Expense</span>
                <h1 class="display-6 fw-bold">@ViewBag.TotalExpense</h1>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="d-flex flex-row widget summary balance">
            <div class="d-flex flex-column justify-content-center p-5">
                <i class="fa-solid fa-dollar-sign fa-2xl"></i>
            </div>
            <div class="d-flex flex-column m-auto py-3">
                <span class="lead">Remaining Balance</span>
                <h1 class="display-6 fw-bold">@ViewBag.Balance</h1>
            </div>
        </div>
    </div>
</div>

@if (ViewBag.HasBudget == true)
{
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="widget p-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold m-0">Monthly Budget Progress</h5>
                    <span class="text-muted">Based on Projected Income: <b class="text-success">@ViewBag.ProjectedIncome</b></span>
                </div>
                <div class="row">
                    @foreach (var item in ViewBag.BudgetProgress as List<ExpenseTracker.ViewModels.CategoryProgressViewModel>)
                    {
                        <div class="col-md-6 mb-4">
                            <div class="d-flex justify-content-between mb-1">
                                <span>@item.CategoryIcon @item.CategoryTitle</span>
                                <span>@item.FormattedSpent / <small class="text-muted">@item.FormattedAllocated</small></span>
                            </div>
                            <div class="progress" style="height: 10px; background-color: #2c343f;">
                                <div class="progress-bar @(item.ProgressPercentage > 100 ? "bg-danger" : (item.ProgressPercentage > 85 ? "bg-warning" : "bg-success"))" 
                                     role="progressbar" 
                                     style="width: @(Math.Min(item.ProgressPercentage, 100))%" 
                                     aria-valuenow="@item.ProgressPercentage" 
                                     aria-valuemin="0" 
                                     aria-valuemax="100">
                                </div>
                            </div>
                            @if (item.ProgressPercentage > 100)
                            {
                                <small class="text-danger">Over budget by @((item.ActualSpent - item.AllocatedAmount).ToString("C2"))</small>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="widget p-4 text-center">
                <h5 class="text-muted">No budget plan found for this month.</h5>
                <a href="/Budget" class="btn btn-outline-primary mt-2">
                    <i class="fa-solid fa-plus me-2"></i>Create Budget Plan
                </a>
            </div>
        </div>
    </div>
}

@*Doughnut and Spline Chart*@
<div class="row mb-4">
    <div class="col-md-4">
        <div class="widget chart">
            <div class="p-4">
                <h5 class="fw-bold">Expense By Category</h5>
            </div>
            <ejs-accumulationchart id="doughnutchart" enableSmartLabels background="#1a222b">
                <e-accumulation-series-collection>
                    <e-accumulation-series dataSource="@ViewBag.Expenses"
                                           xName="categoryTitleWithIcon" yName="amount"
                                           innerRadius="60%" legendShape="Circle"
                                           palettes=@(new string[]{"#0e8d76","#a4b219","#cb9b00","#8a442c","#0454b5","#7d0a0a","#822690","#4c2090","#313e93","#0096ac"})>
                        <e-accumulationseries-datalabel name="formattedAmount" visible></e-accumulationseries-datalabel>
                    </e-accumulation-series>
                </e-accumulation-series-collection>
                <e-accumulationchart-legendsettings position="Top" toggleVisibility="false">
                    <e-legendsettings-textstyle color="#fff" size="1rem"></e-legendsettings-textstyle>
                </e-accumulationchart-legendsettings>
                <e-accumulationchart-tooltipsettings enable></e-accumulationchart-tooltipsettings>
            </ejs-accumulationchart>
        </div>
    </div>
    <div class="col-md-8">
        <h4>Income</h4>
        <ejs-grid id="income" dataSource="@ViewBag.Income" gridLines="None" allowPaging="true">
            <e-grid-pagesettings pageSize="2"></e-grid-pagesettings>
            <e-grid-columns>
                <e-grid-column headerText="Category" field="categoryTitleWithIcon"></e-grid-column>
                <e-grid-column headerText="Amount" field="formattedAmount" format="c2"></e-grid-column>
            </e-grid-columns>
        </ejs-grid>
        <h4>Expenses</h4>
        <ejs-grid id="expenses" dataSource="@ViewBag.Expenses" gridLines="None" allowPaging="true">
            <e-grid-pagesettings pageSize="5"></e-grid-pagesettings>
            <e-grid-columns>
                <e-grid-column headerText="Category" field="categoryTitleWithIcon"></e-grid-column>
                <e-grid-column headerText="Amount" field="formattedAmount" format="c2"></e-grid-column>
            </e-grid-columns>
            </ejs-grid>
            </div>
            </div>

            @section Scripts {
            <script>
            function onDateChange(args) {
            if (args.value) {
                const date = args.value;
                const formattedDate = date.getFullYear() + "-" + (date.getMonth() + 1) + "-01";
                window.location.href = "/Dashboard?date=" + formattedDate;
            }
            }
            </script>
            }